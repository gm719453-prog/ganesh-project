{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd aids_department_website/frontend && npm install --legacy-peer-deps",
  "buildCommand": "cd aids_department_website/frontend && npx ng build --configuration production",
  "outputDirectory": "aids_department_website/frontend/dist/frontend/browser",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
